{
	"version": "2.0.0",
	"tasks": [
	  {
		"type": "shell",
		"label": "C/C++: g++.exe build active file",
		"command": "g++",
		"args": [
			"--std=c++17",
			"${file}",
			"-o", 
			"test.exe"
		],
		"options": {
		  "cwd": "${workspaceFolder}"
		},
		"problemMatcher": ["$gcc"],
		"group": {
		  "kind": "build",
		  "isDefault": true
		}
	  }
	]
  }